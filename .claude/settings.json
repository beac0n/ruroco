{
  "permissions": {
    "allow": [
      "Bash(make:*)"
    ]
  },
  "prefersReducedMotion": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make format"
          },
          {
            "type": "command",
            "command": "make check"
          }
        ]
      }
    ]
  }
}
